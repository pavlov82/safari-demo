---
import { APP_BLOG } from 'astrowind:config';

import { getBlogPermalink } from '~/utils/permalinks';
import { findLatestPosts } from '~/utils/blog';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Widget } from '~/types';
import Button from '~/components/ui/Button.astro';

export interface Props extends Widget {
  title?: string;
  count?: number;
}

const {
  title = 'I Nostri Safari Più Affascinanti',
  count = 6,
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const posts = APP_BLOG.isEnabled ? await findLatestPosts({ count }) : [];
---

{
  APP_BLOG.isEnabled ? (
    <WidgetWrapper id={id} isDark={isDark} containerClass={classes?.container as string} bg={bg}>
      <div class="mb-12">
        {title && (
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl sm:leading-none group font-heading mb-8">
            {title}
          </h2>
        )}
      </div>

      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700">
        <table class="w-full">
          <thead class="bg-gradient-to-r from-slate-100 to-slate-50 dark:from-slate-800 dark:to-slate-700">
            <tr>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 dark:text-white whitespace-nowrap">
                Titolo
              </th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 dark:text-white whitespace-nowrap">
                Categoria
              </th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 dark:text-white whitespace-nowrap">
                Autore
              </th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 dark:text-white whitespace-nowrap">
                Data
              </th>
              <th class="px-6 py-4 text-center text-sm font-semibold text-gray-900 dark:text-white whitespace-nowrap">
                Azione
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            {posts.map((post) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors">
                <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-100">
                  <div class="flex items-center gap-3">
                    {post.image && (
                      <img src={post.image} alt={post.title} class="w-12 h-12 rounded object-cover" />
                    )}
                    <span class="font-medium">{post.title}</span>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm">
                  <span class="inline-block px-3 py-1 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-100 text-xs font-medium">
                    {post.category || 'Safari'}
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">{post.author || 'Safari Team'}</td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400 whitespace-nowrap">
                  {post.publishDate ? new Date(post.publishDate).toLocaleDateString('it-IT') : 'N/A'}
                </td>
                <td class="px-6 py-4 text-sm text-center">
                  <a
                    href={post.permalink}
                    class="inline-block px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold transition-colors"
                  >
                    Leggi
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </WidgetWrapper>
  ) : (
    <Fragment />
  )
}
