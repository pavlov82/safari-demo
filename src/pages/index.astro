---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import BlogPostsTable from '~/components/widgets/BlogPostsTable.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Safari Blog - Avventure nel Continente Nero',
  description: 'Scopri i migliori destinazioni safari, guide di viaggio e consigli per esperienze indimenticabili in Africa',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Scopri il Serengeti',
        href: '#posts',
        icon: 'tabler:arrow-down',
      },
      {
        variant: 'secondary',
        text: 'Contattaci',
        href: '/contact',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'African Safari Lion',
    }}
  >
    <Fragment slot='title'>
      Esplorazioni <span class='text-accent dark:text-white'>Safari</span> nel Continente Nero
    </Fragment>

    <Fragment slot='subtitle'>
      <span class='hidden sm:inline'>
Scopri le avventure pi&ugrave; affascinanti della Tanzania, Kenya e Botswana. Guide complete, consigli fotografici e
        esperienze indimenticabili nel cuore della savana africana.
      </span>
      <span class='block mb-1 sm:hidden font-bold text-blue-600'>Safari Africano</span>
      Destinazioni straordinarie, fauna selvatica spettacolare e paesaggi che cambieranno la vostra prospettiva della
      natura.
    </Fragment>
  </Hero>

  <!-- Blog Posts Table Widget ******* -->

  <BlogPostsTable id='posts' />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Pianifica il Tuo Safari',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot='title'>
      Pronto Ad Un'Avventura <br class='block sm:hidden' /><span class='sm:whitespace-nowrap'>Indimenticabile?</span>
    </Fragment>

    <Fragment slot='subtitle'>
      Contattaci oggi per ricevere consulenza personalizzata e creare l'esperienza safari perfetta per te.
    </Fragment>
  </CallToAction>
</Layout>
