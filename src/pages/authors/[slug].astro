---
import Layout from '~/layouts/PageLayout.astro';
import type { AstroGlobal } from 'astro';

export const prerender = true;

export async function getStaticPaths() {
  const slugs = [
    'marco-rossi',
    'david-kimani',
    'elena-verdi',
    'lisa-martinez',
    'james-muturi',
    'anna-kinyanjui',
  ];
  return slugs.map((slug) => ({ params: { slug } }));
}

interface AuthorInfo {
  name: string;
  bio: string;
  image?: string;
}

const authors: Record<string, AuthorInfo> = {
  'marco-rossi': {
    name: 'Marco Rossi',
    bio: 'Marco è un esperto guida safari con oltre 15 anni di esperienza in Tanzania. Ama condividere la sua passione per la fauna selvaggia e catturare momenti indimenticabili per i suoi ospiti.',
  },
  'david-kimani': {
    name: 'David Kimani',
    bio: "David è un conservazionista keniota che lavora a stretto contatto con le comunità locali per promuovere il turismo sostenibile e la protezione della fauna."
  },
  'elena-verdi': {
    name: 'Elena Verdi',
    bio: 'Fotografa professionista italiana specializzata in wildlife. Ha viaggiato in tutti i parchi africani per immortalare le emozioni più autentiche della savana.',
  },
  'lisa-martinez': {
    name: 'Lisa Martinez',
    bio: 'Lisa è una naturalista e scrittrice che documenta le grandi migrazioni africane. Il suo lavoro ha ispirato molti a comprendere il ciclo della vita selvaggia.',
  },
  'james-muturi': {
    name: 'James Muturi',
    bio: 'James, residente in Botswana, è noto per i suoi tour dedicati agli elefanti. Crede nel rispetto totale degli animali e nella condivisione della loro storia.',
  },
  'anna-kinyanjui': {
    name: 'Anna Kinyanjui',
    bio: 'Anna è un"ornitologa" con occhio attento. Organizza safari per birdwatcher e ha catalogato oltre 800 specie nel suo diario personale.',
  },
};

const { slug } = Astro.params as { slug: string };
const author = authors[slug] || { name: 'Autore Sconosciuto', bio: 'Profilo non disponibile.' };

const metadata = {
  title: `Autore - ${author.name}`,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 mx-auto max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">{author.name}</h1>
    <p class="text-lg leading-relaxed">{author.bio}</p>
    <p class="mt-8">
      <a href="/" class="text-blue-600 hover:underline">Torna alla home</a>
    </p>
  </section>
</Layout>